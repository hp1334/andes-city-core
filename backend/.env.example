# URL del proyecto Supabase (Obtener desde Dashboard -> Project Settings -> API)
SUPABASE_URL=

# Service Role Key SECRETA para admin privileges (Obtener desde Dashboard -> Project Settings -> API)
SUPABASE_SERVICE_KEY=

# Clave API de Anthropic para agente IA (Obtener desde console.anthropic.com)
CLAUDE_API_KEY=

# Clave API para clima (ej. OpenWeatherMap)
WEATHER_API_KEY=

# Entorno de despliegue (development | production)
APP_ENV=development

# Patrones CORS permitidos frontend (desarrollo: http://localhost:8081)
ALLOWED_ORIGINS=http://localhost:8081
